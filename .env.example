# SkyStratos Fleet Intelligence — Environment Variables
# Copy to .env.local and fill in values

# Required: Anthropic API key for Tower AI copilot
ANTHROPIC_API_KEY=your_anthropic_key_here

# Demo PIN for PINGate authentication
DEMO_PIN=change-me-to-a-secure-pin

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Public site URL
NEXT_PUBLIC_SITE_URL=https://skystratos.com
